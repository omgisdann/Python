pessoas = {}
def cadastro ():
    '''parte do nome'''
    first_flag = True
    while first_flag:
        nome = input("digite seu nome! ")
        variavel = nome.isdigit()
        if variavel == True:
            print("digite um nome válido!")
        else:
            pessoas['NOME'] = nome
            first_flag = False  

    '''parte da idade'''
    second_flag = True
    while second_flag:
        try:
            idade = int(input("digite a sua idade "))
            pessoas['IDADE'] = idade
            second_flag=False
        except ValueError:
            print("digite um valor válido!")

    '''parte do local'''
    third_flag = True
    while third_flag:
        residencia = input("digite o local onde reside ")
        variavel = residencia.isdigit()
        if variavel == True:
            print("digite um nome válido!")
        else:
            pessoas['RESIDÊNCIA'] = residencia
            third_flag = False
            
            
        
    '''depósito do dinheiro!'''
    fourth_flag = True
    while fourth_flag:
        try:
            dinheiro = float(input("digite a quantidade de dinheiro "))
            pessoas['CONTA'] = dinheiro
            fourth_flag=False
            return pessoas
        except ValueError:
            print("digite um valor válido!")


